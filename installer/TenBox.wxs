<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="TenBox"
           Manufacturer="TenClass"
           Version="$(var.ProductVersion)"
           UpgradeCode="77F75DD3-2517-4A59-90E9-9A030242A116"
           Scope="perMachine"
           InstallerVersion="500"
           Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of TenBox is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Installer UI with directory selection -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />

    <!-- Use project's GPL v3 license -->
    <WixVariable Id="WixUILicenseRtf" Value="$(var.ProjectDir)\installer\license.rtf" />

    <!-- Completion dialog: "Launch TenBox" checkbox -->
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="Launch TenBox" />
    <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />
    <SetProperty Id="WixShellExecTarget" Value="[INSTALLFOLDER]tenbox-manager.exe"
                 After="CostFinalize" Sequence="ui" />
    <CustomAction Id="LaunchApplication" DllEntry="WixShellExec" Impersonate="yes"
                  BinaryRef="Wix4UtilCA_X86" />
    <UI>
      <Publish Dialog="ExitDialog" Control="Finish" Event="DoAction" Value="LaunchApplication"
               Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 and NOT Installed" />
    </UI>

    <!-- Install to 64-bit Program Files\TenBox -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="TenBox">
        <Component Id="ManagerExe" Guid="*" Bitness="always64">
          <File Id="TenBoxManager" Source="$(var.BuildDir)\tenbox-manager.exe" KeyPath="yes" />
        </Component>
        <Component Id="RuntimeExe" Guid="*" Bitness="always64">
          <File Id="TenBoxRuntime" Source="$(var.BuildDir)\tenbox-vm-runtime.exe" KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Start Menu shortcut -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="TenBoxMenuFolder" Name="TenBox">
        <Component Id="StartMenuShortcut" Guid="*">
          <Shortcut Id="ManagerShortcut"
                    Name="TenBox"
                    Target="[INSTALLFOLDER]tenbox-manager.exe"
                    WorkingDirectory="INSTALLFOLDER" />
          <RemoveFolder Id="RemoveMenuFolder" On="uninstall" />
          <RegistryValue Root="HKCU" Key="Software\TenClass\TenBox"
                         Name="startmenu" Type="integer" Value="1"
                         KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Desktop shortcut -->
    <StandardDirectory Id="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="*">
        <Shortcut Id="DesktopManagerShortcut"
                  Name="TenBox"
                  Target="[INSTALLFOLDER]tenbox-manager.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RegistryValue Root="HKCU" Key="Software\TenClass\TenBox"
                       Name="desktop_shortcut" Type="integer" Value="1"
                       KeyPath="yes" />
      </Component>
    </StandardDirectory>

    <Feature Id="Main" Title="TenBox" Level="1">
      <ComponentRef Id="ManagerExe" />
      <ComponentRef Id="RuntimeExe" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="DesktopShortcut" />
    </Feature>
  </Package>
</Wix>
